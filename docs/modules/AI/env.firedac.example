п»ї# ============================================================
#  MinusAI MCP Server - ConfiguraГѓВ§ГѓВЈo de ConexГѓВµes FireDAC
# ============================================================
# Defina estas variГѓВЎveis de ambiente antes de executar o
# servidor MCP para ativar a conexГѓВЈo real com banco de dados.
#
# Uso no PowerShell:
#   $env:MCP_DB_DRIVER="PG"
#   $env:MCP_DB_SERVER="localhost"
#   $env:MCP_DB_DATABASE="meu_banco"
#   $env:MCP_DB_USERNAME="postgres"
#   $env:MCP_DB_PASSWORD="postgres"
#   MinusAI_MCP.exe
#
# Uso no CMD:
#   set MCP_DB_DRIVER=PG
#   MinusAI_MCP.exe
#
# ============================================================
# ConexГѓВЈo padrГѓВЈo (usada quando nenhum nome ГѓВ© especificado)
# ============================================================
# Driver suportados: PG (PostgreSQL), FB (Firebird),
#   SQLite, MySQL, MSSQL (SQL Server), Oracle, ODBC
MCP_DB_DRIVER=PG
MCP_DB_SERVER=localhost
MCP_DB_DATABASE=meu_banco
MCP_DB_USERNAME=postgres
MCP_DB_PASSWORD=postgres
MCP_DB_PORT=5432

# ============================================================
# ConexГѓВµes nomeadas (opcionais)
# ============================================================
# Use MCP_DB_<NOME>_* para conexГѓВµes adicionais.
# O parГѓВўmetro "conexao" nas ferramentas MCP referencia estes nomes.
#
# Exemplo: conexГѓВЈo "analytics"
MCP_DB_ANALYTICS_DRIVER=MySQL
MCP_DB_ANALYTICS_SERVER=192.168.1.100
MCP_DB_ANALYTICS_DATABASE=analytics
MCP_DB_ANALYTICS_USERNAME=etl_user
MCP_DB_ANALYTICS_PASSWORD=secret123
MCP_DB_ANALYTICS_PORT=3306

# Exemplo: conexГѓВЈo "legado" (Firebird)
MCP_DB_LEGADO_DRIVER=FB
MCP_DB_LEGADO_SERVER=localhost
MCP_DB_LEGADO_DATABASE=C:\Dados\ERP.FDB
MCP_DB_LEGADO_USERNAME=SYSDBA
MCP_DB_LEGADO_PASSWORD=masterkey
MCP_DB_LEGADO_PORT=3050
